LLM_ENABLED=false
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=20
LLM_TEMPERATURE=0
LLM_MAX_INPUT_LINES=2500
SAFETY_MODE=balanced
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_HOST_ORIGIN_PROTECTION=true

# For Cloudflare Tunnel / remote LM Studio:
# MCP_TRANSPORT=http
# MCP_HOST=127.0.0.1
# MCP_PORT=8000
# MCP_HOST_ORIGIN_PROTECTION=false
